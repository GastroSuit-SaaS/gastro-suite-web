{
  "name": "gastro-suite-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run sync:firebase-sw && vite",
    "build": "npm run sync:firebase-sw && vite build && node scripts/verify-production-build.js && node scripts/verify-dist-assets.js && node scripts/copy-spa-fallback.js",
    "sync:firebase-sw": "node scripts/sync-firebase-sw.mjs",
    "deploy:pages": "npm run build && npx wrangler pages deploy dist --project-name=gastro-suite-web",
    "build:only": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@stomp/stompjs": "^7.3.0",
    "axios": "^1.13.6",
    "firebase": "^11.10.0",
    "pinia": "^3.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "vite": "^7.2.4"
  }
}
