# Vite embebe estas variables en `npm run build` (modo production).
# Cloudflare Pages: puedes duplicarlas en Environment variables del proyecto.
# Frontend: https://gastro-suite.metasoft.pe

# ── API Railway (obligatorio) ─────────────────────────────────────────────────
VITE_PLATFORM_API_URL=https://gastro-api-preprod-production-1ece.up.railway.app/api/v1
VITE_WS_OPERATIONAL_URL=wss://gastro-api-preprod-production-1ece.up.railway.app/ws/operational

# ── Paths BFF (relativos a VITE_PLATFORM_API_URL) ───────────────────────────
VITE_IAM_ENDPOINT=/auth
VITE_COMPANIES_ENDPOINT=/companies
VITE_BRANCHES_ENDPOINT=/branches
VITE_TABLES_ENDPOINT=/tables
VITE_ZONES_ENDPOINT=/zones
VITE_RESERVATIONS_ENDPOINT=/reservations
VITE_MENU_ENDPOINT=/menu-items
VITE_CATEGORIES_ENDPOINT=/menu-categories
VITE_POS_ENDPOINT=/pos/sales
VITE_TICKETS_ENDPOINT=/pos/tickets
VITE_POS_OPERATIONS_CONFIG_ENDPOINT=/pos/operations-config
VITE_STATIONS_ENDPOINT=/stations
VITE_PAYMENTS_ENDPOINT=/payments
VITE_CASH_REGISTER_ENDPOINT=/cash-register/movements
VITE_CASH_REGISTER_SESSIONS_ENDPOINT=/cash-register/sessions
VITE_INVENTORY_ENDPOINT=/inventory/products
VITE_INVENTORY_CATEGORIES_ENDPOINT=/inventory/categories
VITE_INVENTORY_MOVEMENTS_ENDPOINT=/inventory/movements
VITE_USERS_ENDPOINT=/employees
VITE_REPORTS_ENDPOINT=/reports
VITE_DASHBOARD_ENDPOINT=/dashboard

# ── POS (opcional; por defecto el API exige líneas enviadas a cocina) ──────────
# VITE_POS_BILLABLE_REQUIRES_SENT=true

# ── Platform (alinear con GASTRO_PLATFORM_ENABLED en API) ─────────────────────
VITE_PLATFORM_ENABLED=true
VITE_PLATFORM_BOOTSTRAP_ENABLED=false

# ── Firebase FCM (push web) — embebido en build + firebase-messaging-sw.js ───
