VITE_FIREBASE_API_KEY=AIzaSyAh2nXjZIW5dWci5GH-ibsR7ysRxGas_Dg
VITE_FIREBASE_AUTH_DOMAIN=upc-pre-iot-metasoft.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=upc-pre-iot-metasoft
