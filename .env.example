# Copia como .env (local) o define estas variables en Railway/CI ANTES de `npm run build`.
# Vite embebe los valores en el bundle; cambiarlas en runtime sin rebuild no tiene efecto.

# ── Host de la API (obligatorio en producción — se embebe en el build) ───────
# Railway: Variables del servicio WEB → Build → redeploy completo (no solo restart).
# NO uses VITE_IAM_ENDPOINT=/support/auth — el registro es POST /auth/sign-up
# Ej. local:     http://localhost:8080/api/v1
# Ej. preprod:   https://gastro-api-preprod-production-1ece.up.railway.app/api/v1
# Ej. producción: https://tu-api-produccion.up.railway.app/api/v1
VITE_PLATFORM_API_URL=http://localhost:8080/api/v1

# WebSocket STOMP (opcional; si se omite se deriva del host de VITE_PLATFORM_API_URL)
# VITE_WS_OPERATIONAL_URL=wss://tu-api.up.railway.app/ws/operational

# ── Auth / onboarding ────────────────────────────────────────────────────────
# sign-in, sign-up y ensure-employee: {VITE_PLATFORM_API_URL}{VITE_IAM_ENDPOINT}/…
VITE_IAM_ENDPOINT=/auth
VITE_COMPANIES_ENDPOINT=/companies

# ── Módulos (paths relativos a VITE_PLATFORM_API_URL) ───────────────────────
VITE_BRANCHES_ENDPOINT=/branches
VITE_TABLES_ENDPOINT=/tables
VITE_ZONES_ENDPOINT=/zones
VITE_RESERVATIONS_ENDPOINT=/reservations
VITE_MENU_ENDPOINT=/menu-items
VITE_CATEGORIES_ENDPOINT=/menu-categories
VITE_POS_ENDPOINT=/pos/sales
VITE_TICKETS_ENDPOINT=/pos/tickets
VITE_POS_OPERATIONS_CONFIG_ENDPOINT=/pos/operations-config
VITE_STATIONS_ENDPOINT=/stations
VITE_PAYMENTS_ENDPOINT=/payments
VITE_CASH_REGISTER_ENDPOINT=/cash-register/movements
VITE_CASH_REGISTER_SESSIONS_ENDPOINT=/cash-register/sessions
VITE_INVENTORY_ENDPOINT=/inventory/products
VITE_INVENTORY_CATEGORIES_ENDPOINT=/inventory/categories
VITE_INVENTORY_MOVEMENTS_ENDPOINT=/inventory/movements
VITE_USERS_ENDPOINT=/employees
VITE_REPORTS_ENDPOINT=/reports
VITE_DASHBOARD_ENDPOINT=/dashboard

# ── Comportamiento POS (opcional) ────────────────────────────────────────────
# VITE_POS_BILLABLE_REQUIRES_SENT=false
