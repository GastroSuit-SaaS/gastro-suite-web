# ── Local ─────────────────────────────────────────────────────────────────────
# Copia como `.env` o crea `.env.development.local` solo con overrides de API:
#
#   VITE_PLATFORM_API_URL=http://localhost:8080/api/v1
#   VITE_WS_OPERATIONAL_URL=ws://localhost:8080/ws/operational
#
# El resto de VITE_* puede copiarse desde este archivo o desde `.env.production`.

# ── Producción (Cloudflare Pages) ─────────────────────────────────────────────
# Usa `.env.production` (versionado) o define las mismas variables en el dashboard
# antes de `npm run build`. Sin rebuild no cambian en runtime.

# API (obligatorio en build de producción)
VITE_PLATFORM_API_URL=https://gastro-api-preprod-production-1ece.up.railway.app/api/v1
VITE_WS_OPERATIONAL_URL=wss://gastro-api-preprod-production-1ece.up.railway.app/ws/operational

# Paths relativos a VITE_PLATFORM_API_URL
VITE_IAM_ENDPOINT=/auth
VITE_COMPANIES_ENDPOINT=/companies
VITE_BRANCHES_ENDPOINT=/branches
VITE_TABLES_ENDPOINT=/tables
VITE_ZONES_ENDPOINT=/zones
VITE_RESERVATIONS_ENDPOINT=/reservations
VITE_MENU_ENDPOINT=/menu-items
VITE_CATEGORIES_ENDPOINT=/menu-categories
VITE_POS_ENDPOINT=/pos/sales
VITE_TICKETS_ENDPOINT=/pos/tickets
VITE_POS_OPERATIONS_CONFIG_ENDPOINT=/pos/operations-config
VITE_STATIONS_ENDPOINT=/stations
VITE_PAYMENTS_ENDPOINT=/payments
VITE_CASH_REGISTER_ENDPOINT=/cash-register/movements
VITE_CASH_REGISTER_SESSIONS_ENDPOINT=/cash-register/sessions
VITE_INVENTORY_ENDPOINT=/inventory/products
VITE_INVENTORY_CATEGORIES_ENDPOINT=/inventory/categories
VITE_INVENTORY_MOVEMENTS_ENDPOINT=/inventory/movements
VITE_USERS_ENDPOINT=/employees
VITE_REPORTS_ENDPOINT=/reports
VITE_DASHBOARD_ENDPOINT=/dashboard

# VITE_POS_BILLABLE_REQUIRES_SENT=false

# ── Firebase Cloud Messaging (push web) ───────────────────────────────────────
# npm run sync:firebase-sw lee gastro-suite-api/secrets/firebase-service-account.json
# y genera .env.development.local + public/firebase-messaging-sw.js
# Producción: definir en .env.production o Cloudflare Pages (mismas VITE_FIREBASE_*)
# VAPID: Firebase Console → Cloud Messaging → Web Push certificates → Key pair
# VITE_FIREBASE_API_KEY=...
# VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=tu-proyecto
# VITE_FIREBASE_MESSAGING_SENDER_ID=...
# VITE_FIREBASE_APP_ID=1:...:web:...
# VITE_FIREBASE_VAPID_KEY=BN...

# ── Platform (PLAN-36) — alinear con GASTRO_PLATFORM_ENABLED en API ───────────
# Dev local: true (application-dev.yml tiene gastrosuite.platform.enabled=true)
# Producción: activar en Cloudflare Pages + Railway antes de usar /platform
VITE_PLATFORM_ENABLED=true
VITE_PLATFORM_BOOTSTRAP_ENABLED=true
